-- 通用 JSON 缓存表
CREATE TABLE json_cache (
    cache_key TEXT PRIMARY KEY NOT NULL,
    json_data TEXT NOT NULL DEFAULT '',
    cached_at INTEGER NOT NULL DEFAULT 0
);

selectCacheByKey:
SELECT * FROM json_cache WHERE cache_key = ?;

insertOrReplaceCache:
INSERT OR REPLACE INTO json_cache(cache_key, json_data, cached_at) VALUES (?, ?, ?);

deleteAllCache:
DELETE FROM json_cache;
